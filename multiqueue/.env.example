# Active la base Supabase/PostgreSQL au lieu de SQLite
USE_SUPABASE=True

# Option 1 : URL complète depuis Supabase > Project Settings > Database > Connection string
# Pour la connexion directe locale, utilisez le port 5432.
# Pour le pooler Supavisor, utilisez généralement le port 6543.
DATABASE_URL=postgresql://postgres:VOTRE_MOT_DE_PASSE@db.VOTRE_PROJECT_REF.supabase.co:5432/postgres

# Option 2 : configuration séparée si vous ne voulez pas utiliser DATABASE_URL
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=VOTRE_MOT_DE_PASSE
# SUPABASE_DB_HOST=db.VOTRE_PROJECT_REF.supabase.co
# SUPABASE_DB_PORT=5432

DATABASE_SSLMODE=require
DATABASE_CONN_MAX_AGE=0
